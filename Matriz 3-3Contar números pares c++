#include <iostream>
using namespace std;

int main() {
    int mat[3][3], pares = 0;
    
    cout << "Digite os valores da matriz 3x3:\n";
    for(int i = 0; i < 3; i++)
        for(int j = 0; j < 3; j++) {
            cin >> mat[i][j];
            if(mat[i][j] % 2 == 0) pares++;
        }
    
    cout << "\nMatriz:\n";
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++)
            cout << mat[i][j] << " ";
        cout << endl;
    }
    
    cout << "\nQuantidade de números pares: " << pares << endl;
    
    return 0;
}