#include <iostream>
using namespace std;

int main() {
    int a[3][3], b[3][3], sub[3][3];
    
    cout << "Digite a primeira matriz 3x3:\n";
    for(int i = 0; i < 3; i++)
        for(int j = 0; j < 3; j++)
            cin >> a[i][j];
    
    cout << "Digite a segunda matriz 3x3:\n";
    for(int i = 0; i < 3; i++)
        for(int j = 0; j < 3; j++)
            cin >> b[i][j];
    
    for(int i = 0; i < 3; i++)
        for(int j = 0; j < 3; j++)
            sub[i][j] = a[i][j] - b[i][j];
    
    cout << "\nMatriz A:\n"; 
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) cout << a[i][j] << " ";
        cout << endl;
    }
    
    cout << "\nMatriz B:\n"; 
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) cout << b[i][j] << " ";
        cout << endl;
    }
    
    cout << "\nMatriz Subtração (A - B):\n"; 
    for(int i = 0; i < 3; i++) {
        for(int j = 0; j < 3; j++) cout << sub[i][j] << " ";
        cout << endl;
    }
    
    return 0;
}